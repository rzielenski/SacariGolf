{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ladder-crests",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-e",
        "const http=require('http'),fs=require('fs');http.createServer((q,s)=>{s.writeHead(200,{'Content-Type':'text/html'});fs.createReadStream('mobile/preview/ladder/index.html').pipe(s)}).listen(5599,()=>console.log('ladder preview on 5599'))"
      ],
      "port": 5599
    },
    {
      "name": "sacari-web",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "web/server.js"
      ],
      "port": 4000
    }
  ]
}
