# Copy to .env and fill in. The web service is read-only against the app DB.

# Postgres connection (same database the app/API uses). On Railway, use the
# internal connection string so no SSL is needed.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Where uploaded avatars are served from (the app API's public host).
BACKEND_URL=https://determined-perfection-production.up.railway.app

# Public origin of THIS website, used to build absolute Open Graph URLs.
SITE_URL=https://sacarigolf.com

# App Store link for the "Get the app" buttons (leave blank to hide them).
APP_STORE_URL=

# Support / contact email shown on the support, privacy, and terms pages.
SUPPORT_EMAIL=support@sacarigolf.com

# Set to "require" if your DATABASE_URL needs SSL (external connections do).
DATABASE_SSL=

PORT=4000
